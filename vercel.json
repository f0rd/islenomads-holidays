{
  "version": 3,
  "build": {
    "env": {
      "NODE_ENV": "production"
    },
    "command": "vite build && esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "outputDirectory": "dist"
  },
  "functions": {
    "api/**": {
      "memory": 1024,
      "maxDuration": 10
    }
  }
}
