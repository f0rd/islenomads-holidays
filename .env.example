# Local environment variables

# MySQL connection string used by the server and integration tests.
# Example: mysql://user:password@localhost:3306/database
DATABASE_URL=

# Optional notification service configuration.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Optional authentication / cookie settings.
JWT_SECRET=
OAUTH_SERVER_URL=
VITE_APP_ID=
OWNER_OPEN_ID=

# Google Maps JS API key (https://console.cloud.google.com/google/maps-apis).
# Required for the /map page to render. Must be set at build time on Vercel.
# Restrict it to your production domain(s) in the Google Cloud Console.
VITE_GOOGLE_MAPS_API_KEY=

# Mapbox public token (https://account.mapbox.com/access-tokens), used by the
# legacy MaldivesMapNew page. Optional if /map is the only entry point.
VITE_MAPBOX_TOKEN=

# Umami analytics endpoint and website ID. Without these, the analytics
# <script> tag in client/index.html keeps its literal %VAR% placeholders.
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
