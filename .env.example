# Local environment variables

# Postgres connection string for Supabase (or self-hosted Postgres).
# Example: postgres://user:password@host:5432/database
DATABASE_URL=

# Supabase Auth — required for the staff email/password login flow.
# Find these in the Supabase dashboard → Project Settings → API.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Session cookie signing secret. Generate with `openssl rand -hex 32`.
JWT_SECRET=

# Optional notification service configuration.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Legacy OAuth settings — only needed if you still use the OAuth callback
# at /api/oauth/callback. Safe to leave empty when using Supabase Auth.
OAUTH_SERVER_URL=
VITE_APP_ID=
OWNER_OPEN_ID=

# Google Maps JS API key (https://console.cloud.google.com/google/maps-apis).
# Required for the /map page to render. Must be set at build time on Vercel.
# Restrict it to your production domain(s) in the Google Cloud Console.
VITE_GOOGLE_MAPS_API_KEY=

# Mapbox public token (https://account.mapbox.com/access-tokens), used by the
# legacy MaldivesMapNew page. Optional if /map is the only entry point.
VITE_MAPBOX_TOKEN=

# Umami analytics endpoint and website ID. Without these, the analytics
# <script> tag in client/index.html keeps its literal %VAR% placeholders.
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
